# =============================================================
# Configuración central de personalización del cliente RustDesk
# =============================================================
# Este archivo es la ÚNICA fuente de verdad del branding.
# El script scripts/apply-branding.ps1 lee estos valores y los
# aplica sobre el código fuente clonado en ./rustdesk.
#
# ⚠️ RELLENAR los valores marcados como CAMBIAR antes de compilar.

# --- Identidad de la aplicación -------------------------------
# Nombre comercial visible (ventanas, instalador, bandeja)
APP_NAME=Fontis Remote
# Nombre técnico sin espacios (ejecutable, carpetas de config, servicio)
APP_ID=FontisRemote
# Editor / empresa (metadatos del ejecutable de Windows)
COMPANY=Fontis Beratung
# Repositorio del fork (URLs del README; sin barra final)
REPO_URL=https://github.com/FontisBeratungDev/Fontis-Remote

# --- Servidor propio (se embebe en el binario) ----------------
# Host o IP del servidor hbbs (ID/Rendezvous). Sin puerto = 21116
RENDEZVOUS_SERVER=rustdesk.fontisberatung.ch
# Clave pública del servidor: contenido del archivo id_ed25519.pub
# que está en el directorio de datos de hbbs
RS_PUB_KEY=pOjg1dA09pHunbiZa9s9jjap3EnJDn1MbhTksVdDGPo=
# Servidor API (solo si usan RustDesk Server Pro o rustdesk-api).
# Dejar vacío si solo tienen hbbs/hbbr open source.
API_SERVER=

# --- Assets de marca (en branding/icons/) ---------------------
# Logo horizontal para la cabecera de la app (máx. 300x60 visible)
LOGO_FILE=logo_fontis_primary.png
# Icono cuadrado de la app: colocar branding/icons/icon-1024.png
# (1024x1024 PNG con transparencia). Si no existe, el script genera
# un placeholder a partir del logo horizontal.
# Variantes opcionales de logo: logo_light.png / logo_dark.png

# --- Comportamiento por defecto (opcional) --------------------
# true = el usuario NO puede cambiar el servidor desde ajustes
LOCK_SERVER_SETTINGS=true

# --- Versión ---------------------------------------------------
# Etiqueta de RustDesk sobre la que se construye
UPSTREAM_TAG=1.4.8
